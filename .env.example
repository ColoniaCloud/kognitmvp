# Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://wpjufgefhcyncseuikel.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Web Push — clave pública VAPID (segura de exponer en el cliente).
# Generarla con: bunx web-push generate-vapid-keys
# La clave PRIVADA correspondiente NUNCA va acá ni en ningún archivo del repo:
# se configura como secret de la Edge Function (ver supabase/functions/send-reminder-push).
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=...
VITE_VAPID_PUBLIC_KEY=

# Mercado Pago — public key (segura de exponer en el cliente, la usa el Brick
# de tarjeta para tokenizar). El access token (secreto) NUNCA va acá: se
# configura como secret de la Edge Function con `supabase secrets set`.
VITE_MERCADOPAGO_PUBLIC_KEY=
